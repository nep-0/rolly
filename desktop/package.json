{
  "name": "rolly-desktop",
  "private": true,
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "build:backend": "go build -o dist/backend/rolly.exe ../cmd/rolly",
    "start": "npm run build:backend && electron .",
    "dist": "npm run build:backend && electron-builder"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.rolly.app",
    "productName": "Rolly",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../frontend",
        "to": "frontend"
      },
      {
        "from": "dist/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
